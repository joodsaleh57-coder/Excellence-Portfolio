{
  "manifest_version": 3,
  "name": "Excellence Portfolio – ملف التميز الرقمي",
  "version": "1.0.0",
  "description": "أداة جمع الشواهد وتصدير تقارير التحسين من منصات مدرستي ونور",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "webRequest",
    "offscreen"
  ],
  "host_permissions": [
    "https://madrasati.edu.sa/*",
    "https://noor.moe.gov.sa/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Excellence Portfolio"
  },
  "side_panel": {
    "default_path": "side-panel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://madrasati.edu.sa/*",
        "https://noor.moe.gov.sa/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["https://madrasati.edu.sa/*", "https://noor.moe.gov.sa/*"]
    }
  ],
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}
